DATABASE_URL="postgresql://hoteluser:hotelpass@localhost:5432/hoteldb"
REDIS_URL="redis://localhost:6379"
PORT=3001
NODE_ENV=development

# JWT RS256 — paths to PEM files (or inline PEMs). Generated by scripts/generate-jwt-keys.sh
JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Firebase admin SDK — path to service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-admin.json
