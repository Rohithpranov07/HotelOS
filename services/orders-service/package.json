{
  "name": "orders-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "schema": "../auth-service/prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@hotel-os/types": "workspace:*",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.77.3",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^6.19.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@hotel-os/config": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
