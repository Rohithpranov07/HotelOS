# ─── Database & cache ──────────────────────────
DATABASE_URL=postgresql://hoteluser:hotelpass@localhost:5432/hoteldb
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256) ───────────────────────────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ─── Auth / SMS ───────────────────────────────
FIREBASE_SERVICE_ACCOUNT=

# ─── AI ───────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=hotel-knowledge-base

# ─── Payments ─────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── PMS ──────────────────────────────────────
CLOUDBEDS_API_KEY=
CLOUDBEDS_WEBHOOK_SECRET=

# ─── Email ────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@hotelosapp.io

# ─── AWS / S3 ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# ─── Service ports ────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Mobile app (Expo) ────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_ORDERS_WS_URL=ws://localhost:3003
